#if defined (__cplusplus) && __cplusplus <= 1
namespace stdgak
{
	template <typename ObjT>
	class unique_ptr_base : gak::CopyProtection
	{
		protected:
		ObjT	*m_ptr;
		unique_ptr_base(ObjT	*ptr=nullptr) : m_ptr(ptr) {}

		public:
		ObjT *release ()
		{
			ObjT *result = m_ptr;
			m_ptr = nullptr;
			return result;
		}
		void swap( unique_ptr_base &other )
		{
			ObjT *tmp = m_ptr;
			m_ptr = other.m_ptr;
			other.m_ptr = tmp;
		}

		operator bool() const
		{
			return m_ptr != nullptr;
		}

		ObjT &operator * () const
		{
			return *m_ptr;
		}

		// get
		ObjT *operator -> () const
		{
			return m_ptr;
		}
		ObjT *get () const
		{
			return m_ptr;
		}
	};
}

template <typename ObjT>
class unique_ptr : public stdgak::unique_ptr_base<ObjT>
{
	public:
	unique_ptr(ObjT *ptr=nullptr) : stdgak::unique_ptr_base<ObjT>(ptr)
	{}
	~unique_ptr()
	{
		reset();
	}
	void reset( ObjT *ptr=nullptr )
	{
		if( ptr != this->m_ptr )
		{
			if( this->m_ptr )
				delete this->m_ptr;
			this->m_ptr = ptr;
		}
	}
};

template < typename ObjT >
class unique_ptr<ObjT[]> : public stdgak::unique_ptr_base<ObjT>
{
	public:
	unique_ptr(ObjT *ptr=nullptr) : stdgak::unique_ptr_base<ObjT>(ptr)
	{}
	~unique_ptr()
	{
		reset();
	}
	void reset( ObjT *ptr=nullptr )
	{
		if( ptr != this->m_ptr )
		{
			if( this->m_ptr )
				delete [] this->m_ptr;
			this->m_ptr = ptr;
		}
	}
};
